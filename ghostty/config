# Font
font-family = JetBrainsMono Nerd Font
font-size = 14

# Theme
theme = Catppuccin Latte

# Window
window-padding-x = 10
window-padding-y = 8
window-decoration = true

# Cursor
cursor-style = block
cursor-style-blink = true

# Behavior
copy-on-select = true
window-save-state = always

# Shell integration
shell-integration = zsh
